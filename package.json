{
  "name": "inspector",
  "version": "2.0.0",
  "description": "HIS/EMR Observability & Safety-Gate Browser — automated auditor for enterprise healthcare applications",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.inspector.healthcare",
    "productName": "Inspector Healthcare",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "reporting.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [{
        "target": "portable",
        "arch": ["x64"]
      }],
      "artifactName": "Inspector-Healthcare-${version}-portable.exe"
    }
  },
  "dependencies": {
    "axe-core": "^4.10.0",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
